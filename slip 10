1) Write a function using cursor which accepts city name as
input and prints the details of all customers in that city.

CREATE OR REPLACE FUNCTION cust_by_city(ct VARCHAR)
RETURNS VOID
LANGUAGE plpgsql
AS $$
DECLARE
 cno_var INT;
 cname_var VARCHAR(20);
 city_var VARCHAR(20);

 cur CURSOR FOR
 SELECT cno, cname, city 
 FROM Customer
 WHERE city = ct;
BEGIN
 OPEN cur;

 LOOP
 FETCH cur INTO cno_var, cname_var, city_var;
 EXIT WHEN NOT FOUND;

 RAISE NOTICE 'Cno: %, Name: %, City: %',
 cno_var, cname_var, city_var;
 END LOOP;

 CLOSE cur;
END;
$$;

2) Write a procedure to display all customers from ‘Pune’ city.
CREATE OR REPLACE PROCEDURE pune_customers()
LANGUAGE plpgsql
AS $$
DECLARE
 rec RECORD;
BEGIN
 FOR rec IN SELECT * FROM Customer WHERE city = 'Pune'
 LOOP
 RAISE NOTICE 'Cno: %Name: %, City: %',
 rec.cno, rec.cname, rec.city;
 END LOOP;
END;
$$;


 
