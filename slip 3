1) Write a stored function using cursors, to calculate total
marks of each student and display it.
CREATE OR REPLACE FUNCTION total_marks()
RETURNS VOID
LANGUAGE plpgsql
AS $$
DECLARE
 r RECORD;
 total INTEGER;
 cur CURSOR FOR SELECT rollno FROM Student;
BEGIN
 OPEN cur;
 LOOP
 FETCH cur INTO r;
 EXIT WHEN NOT FOUND;
 SELECT SUM(marks_scored) INTO total
 FROM Student_Subject
 WHERE rollno = r.rollno;
 RAISE NOTICE 'Roll No = %, Total Marks = %', r.rollno, total;
 END LOOP;
 CLOSE cur;
END;
$$;


2 ) Check the number is positive, negative or zero.
CREATE OR REPLACE PROCEDURE check_num(n INT)
LANGUAGE plpgsql
AS $$
BEGIN
 IF n > 0 THEN
 RAISE NOTICE 'Number is Positive';
 ELSIF n < 0 THEN
 RAISE NOTICE 'Number is Negative';
 ELSE
 RAISE NOTICE 'Number is Zero';
 END IF;
END;
$$;
