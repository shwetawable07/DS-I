Q3) Write a C program which uses Binary search tree library and implements following function with recursion:
int copy(T) — create another BST which is exact copy of BST which is passed as parameter:
int compare(T1 , T2) — compares two binary search trees and returns I if they are equal and O otherwise.


#include<stdio.h>
#include<stdlib.h>

struct node
{
    int data;
    struct node *left;
    struct node *right;
};

/* Create Node */
struct node* create(int value)
{
    struct node *temp;
    temp = (struct node*)malloc(sizeof(struct node));

    temp->data = value;
    temp->left = NULL;
    temp->right = NULL;

    return temp;
}

/* Insert Node in BST */
struct node* insert(struct node *root, int value)
{
    if(root == NULL)
        return create(value);

    if(value < root->data)
        root->left = insert(root->left, value);
    else
        root->right = insert(root->right, value);

    return root;
}

/* Copy BST */
struct node* copy(struct node *root)
{
    if(root == NULL)
        return NULL;

    struct node *newNode = create(root->data);

    newNode->left = copy(root->left);
    newNode->right = copy(root->right);

    return newNode;
}

/* Compare two BSTs */
int compare(struct node *T1, struct node *T2)
{
    if(T1 == NULL && T2 == NULL)
        return 1;

    if(T1 == NULL || T2 == NULL)
        return 0;

    if(T1->data != T2->data)
        return 0;

    return compare(T1->left, T2->left) &&
           compare(T1->right, T2->right);
}

/* Inorder Traversal */
void inorder(struct node *root)
{
    if(root != NULL)
    {
        inorder(root->left);
        printf("%d ", root->data);
        inorder(root->right);
    }
}

int main()
{
    struct node *T1=NULL, *T2=NULL;
    int n,value,i;

    printf("Enter number of nodes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("Enter value: ");
        scanf("%d",&value);
        T1 = insert(T1,value);
    }

    /* Copy Tree */
    T2 = copy(T1);

    printf("\nOriginal Tree (Inorder): ");
    inorder(T1);

    printf("\nCopied Tree (Inorder): ");
    inorder(T2);

    /* Compare Trees */
    if(compare(T1,T2))
        printf("\nTrees are Equal\n");
    else
        printf("\nTrees are Not Equal\n");

    return 0;
}
