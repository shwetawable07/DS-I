Q1) Write a C program for the implementation of Topological sorting.
#include <stdio.h>
#include <stdlib.h>
#define MAX 100
int graph[MAX][MAX], visited[MAX], stack[MAX];
int n, top = -1;
void push(int v)
{
stack[++top] = v;
}
void topoSort(int v)
{
visited[v] = 1;
for(int i = 0; i < n; i++)
{
if(graph[v][i] == 1 && visited[i] == 0)
topoSort(i);
}
push(v);
}
int main()
{
int i, j;
printf("Enter number of vertices: ");
scanf("%d", &n);
printf("Enter adjacency matrix:\n");
for(i = 0; i < n; i++)
{
for(j = 0; j < n; j++)
{
scanf("%d", &graph[i][j]);
}
}
for(i = 0; i < n; i++)
visited[i] = 0;
for(i = 0; i < n; i++)
{
if(visited[i] == 0)
topoSort(i);
}
printf("Topological Order: ");
while(top != -1)
{
printf("%d ", stack[top--]);
}
return 0;
}
