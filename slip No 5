1. Write a stored function using cursor to count the number of
customers of particular branch. (Accept branch name as
input parameter).
CREATE OR REPLACE FUNCTION count_customer(bname TEXT)
RETURNS INTEGER
LANGUAGE plpgsql
AS
$$
DECLARE
rec RECORD;
count1 INTEGER := 0;
cur CURSOR FOR
SELECT c.cno
FROM Customer c
JOIN Ternary t ON c.cno=t.cno
JOIN Branch b ON b.br_id=t.br_id
WHERE b.br_name=bname;
BEGIN
OPEN cur;
LOOP
FETCH cur INTO rec;
EXIT WHEN NOT FOUND;
count1 := count1 + 1;
END LOOP;
CLOSE cur;
RETURN count1;
END;
$$;
SELECT count_customer('Main Branch');


2. Write a procedure to find sum of first 20 numbers (using
unconditional loop)
CREATE OR REPLACE PROCEDURE sum_20()
LANGUAGE plpgsql
AS
$$
DECLARE
i INTEGER := 1;
s INTEGER := 0;
BEGIN
LOOP
s := s + i;
i := i + 1;
EXIT WHEN i > 20;
END LOOP;
RAISE NOTICE 'Sum = %', s;
END;
$$;
CALL sum_20();

























