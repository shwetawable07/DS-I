1. Write a stored function to accept the bus number and print
driver name allotted to that bus.
CREATE OR REPLACE FUNCTION get_driver_name(bno INT)
RETURNS TEXT
LANGUAGE plpgsql
AS
$$
DECLARE
dname TEXT;
BEGIN
SELECT driver_name INTO dname
FROM DRIVER d
JOIN BUS_DRIVER bd
ON d.driver_no=bd.driver_no
WHERE bd.bus_no=bno;
RETURN dname;
END;
$$;
SELECT get_driver_name(101);
2. Write a procedure to find number is even or odd.

CREATE OR REPLACE PROCEDURE check_even_odd(n INT)
LANGUAGE plpgsql
AS
$$
BEGIN
IF n%2=0 THEN
RAISE NOTICE 'Number is Even';
ELSE
RAISE NOTICE 'Number is Odd';
END IF;
END;
$$;
CALL check_even_odd(9);






















































