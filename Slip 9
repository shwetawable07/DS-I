1) Write a function to accept department name and display the
maximum salary of an employee in that department.
CREATE OR REPLACE FUNCTION max_salary(dept_name TEXT)
RETURNS MONEY
LANGUAGE plpgsql
AS $$
DECLARE
 max_sal MONEY;
BEGIN
 SELECT MAX(E.salary) INTO max_sal
 FROM Employee E, Department D
 WHERE E.dno = D.dno
 AND D.dname = dept_name;
 RETURN max_sal;
END;
$$;


2) Write a procedure to display multiplication of two numbers.
CREATE OR REPLACE PROCEDURE multiply(a INT, b INT)
LANGUAGE plpgsql
AS $$
DECLARE
 result INT;
BEGIN
 result := a * b;
 RAISE NOTICE 'Multiplication = %', result;
END; 
$$; 
