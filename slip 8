1) Write a function using cursor which accepts a name of student
and returns the total no of prizes won by that student in the year
2020. 
CREATE OR REPLACE FUNCTION total_prizes(sname TEXT)
RETURNS INTEGER
LANGUAGE plpgsql
AS $$
DECLARE
 r RECORD;
 total INTEGER := 0;
 cur CURSOR FOR
 SELECT prize
 FROM STUDENT S, STUDENT_COMPETITION SC
 WHERE S.sreg_no = SC.sreg_no
 AND S.name = sname
 AND SC.year = 2020;
BEGIN
 OPEN cur;
 LOOP
 FETCH cur INTO r;
 EXIT WHEN NOT FOUND;
 total := total + r.prize;
 END LOOP;
 CLOSE cur;
 RETURN total;
END;
$$;


2) Write a procedure to find sum of first 50 numbers (using
unconditional loop).
CREATE OR REPLACE PROCEDURE sum_50()
LANGUAGE plpgsql
AS $$
DECLARE
 i INTEGER := 1;
 s INTEGER := 0;
BEGIN
 LOOP
 s := s + i;
 i := i + 1;
 EXIT WHEN i > 50;
 END LOOP;
 RAISE NOTICE 'Sum of first 50 numbers = %', s;
END;
$$;





