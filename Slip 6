1) Write a stored function to print total number of persons of a
particular area. Accept area name as input parameter.
CREATE OR REPLACE FUNCTION total_persons(area_name
VARCHAR)
RETURNS INT
LANGUAGE plpgsql
AS $$
DECLARE
total INT;
BEGIN
SELECT COUNT(*) INTO total
FROM Person
WHERE aname = area_name;
RETURN total;
END;
$$;
SELECT total_persons('Nashik');


2) Write a procedure to display division of two numbers. Use
raise to display error messages for division by zero error.
CREATE OR REPLACE PROCEDURE divide_no(a INT, b INT)
LANGUAGE plpgsql
AS $$
BEGIN
IF b = 0 THEN
RAISE EXCEPTION 'Division by zero not allowed';
END IF;
RAISE NOTICE 'Division = %', a / b;
END;
$$;
CALL divide_no(10,2);
