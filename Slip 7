1. write a function using cursor to accept year and class to
display student name, competition name and rank.
CREATE OR REPLACE PROCEDURE student_comp(y INT, cls
VARCHAR)
LANGUAGE plpgsql
AS $$
DECLARE
rec RECORD;
cur CURSOR FOR
SELECT s.s_name, c.c_name, sc.rank
FROM Student s, Competition c, Student_Competition sc
WHERE s.sreg_no = sc.sreg_no
AND c.c_no = sc.c_no
AND sc.year = y
AND s.s_class = cls;
BEGIN
OPEN cur;
LOOP
FETCH cur INTO rec;
EXIT WHEN NOT FOUND;
RAISE NOTICE 'Student = %, Competition = %, Rank = %',
rec.s_name, rec.c_name, rec.rank;
END LOOP;
CLOSE cur;
END;
$$;
CALL student_comp(2024,'SYBCS');


2. Write a procedure to find maximum and minimum from three
numbers
CREATE OR REPLACE PROCEDURE max_min(a INT, b INT, c INT)
LANGUAGE plpgsql
AS $$
DECLARE
mx INT;
mn INT;
BEGIN
mx := GREATEST(a,b,c);
mn := LEAST(a,b,c);
RAISE NOTICE 'Maximum = %', mx;
RAISE N
OTICE 'Minimum = %', mn;
END;
$$;
CALL max_min(10,5,20);
