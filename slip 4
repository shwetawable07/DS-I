1. Write a stored function using cursors, to accept class from
the user and display the details of the students of that class.
-- Function
CREATE OR REPLACE FUNCTION student_by_class(cl VARCHAR)
RETURNS VOID
LANGUAGE plpgsql
AS $$
DECLARE
r INT;
n VARCHAR(30);
c VARCHAR(10);

cur CURSOR FOR
SELECT rollno, name, class
FROM Student
WHERE class = cl;

BEGIN
OPEN cur;

LOOP
FETCH cur INTO r, n, c;
EXIT WHEN NOT FOUND;

RAISE NOTICE 'Roll: %, Name: %, Class: %', r, n, c;
END LOOP;

CLOSE cur;
END;
$$;

2. Write a procedure to display all even numbers from 1 to 50.
CREATE OR REPLACE PROCEDURE even_numbers()
LANGUAGE plpgsql
AS $$
DECLARE
 i INT;
BEGIN
 FOR i IN 1..50 LOOP
 IF i % 2 = 0 THEN
 RAISE NOTICE '%', i;
 END IF;
 END LOOP;
END;
$$; 
