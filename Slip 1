1) Write a stored function to accept eno as input parameter and
count number of projects on which that employee is working.
CREATE OR REPLACE FUNCTION count_project(e_id INT)
RETURNS INT
LANGUAGE plpgsql
AS $$
DECLARE
total INT;
BEGIN
SELECT COUNT(pno) INTO total
FROM project_employee
WHERE eno = e_id;
RETURN total;
END;
$$;
SELECT count_project(101);


2) Write a procedure to display addition, subtraction and
multiplication of three numbers.
CREATE OR REPLACE PROCEDURE cal(a INT, b INT, c INT)
LANGUAGE plpgsql
AS $$
BEGIN
RAISE NOTICE 'addition = %', a + b + c;
RAISE NOTICE 'subtraction = %', a - b - c;
RAISE NOTICE 'multiplication = %', a * b * c;
END;
$$;
CALL cal(4,5,6);



















